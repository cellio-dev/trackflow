# Copy to `.env` next to `docker-compose.yml` (Compose loads it for ${VAR} substitution).

SESSION_SECRET=replace-with-a-long-random-string

# --- Host folders (Linux paths on the Docker host) ---

# SQLite + app state (create the directory first: mkdir -p /fast/docker/appdata/trackflow)
TRACKFLOW_APPDATA_HOST_PATH=/fast/docker/appdata/trackflow

# Entire media tree mounted at /media in the container
TRACKFLOW_MEDIA_HOST_PATH=/data/media

# --- Paths inside the container (under the /media mount) — defaults match your layout ---

# Music library root (Plex-style files live here)
LIBRARY_PATH=/media/Music/Tracks

# Where slskd writes completed downloads (must match slskd’s output if you use local moves)
SLSKD_LOCAL_DOWNLOAD_PATH=/media/Downloads/slskd/complete

# Published port (optional)
# TRACKFLOW_PORT=3000

# Behind HTTPS reverse proxy
TRUST_PROXY=1

# slskd API (often on the Docker host)
# SLSKD_BASE_URL=http://host.docker.internal:5030
# SLSKD_API_KEY=

# Plex (optional)
# PLEX_URL=
# PLEX_TOKEN=
