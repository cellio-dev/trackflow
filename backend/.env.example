# Copy to `.env` in this folder. SESSION_SECRET is required; if omitted, the server generates one and appends it to `.env` on first start.
SESSION_SECRET=replace-with-random-string

# Optional: full path to the SQLite file (Docker Compose sets /data/trackflow.sqlite so the DB volume does not replace backend/db/).
# TRACKFLOW_SQLITE_PATH=

# Behind nginx/Caddy with HTTPS, set so session cookies use Secure when the client uses HTTPS (see express trust proxy).
# TRUST_PROXY=1

# Python for mutagen tagging (default on Windows: C:\Python314\python.exe; on Linux/macOS: python3). Docker image sets python3.
# TRACKFLOW_PYTHON=python3
